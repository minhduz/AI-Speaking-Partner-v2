PORT=3000
NODE_ENV=development

# Postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=orchestrator_user
DB_PASS=orchestrator_pass
DB_NAME=speaking_app
DB_SCHEMA=speaking_app

# JWT
JWT_SECRET=change_this_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Internal services (docker network names)
BILLING_SERVICE_URL=http://billing-service:3001
MEMORY_SERVICE_URL=http://memory-service:8001
LLM_GATEWAY_URL=http://llm-gateway:8002
SPEECH_SERVICE_URL=http://speech-service:8010
DICTIONARY_SERVICE_URL=http://dictionary-service:3005
TURN_AGENT_URL=http://turn-agent:8003

# Google OAuth
GOOGLE_CLIENT_ID=

# Root admin (seeded on startup by AdminSeeder)
ADMIN_EMAIL=admin@speakingpartner.local
ADMIN_PASSWORD=change_this_admin_password
# Cost estimate rate for the admin console. Leave at 0 to show token counts
# without a dollar estimate. Set manually based on your provider's pricing
# (USD per 1,000 tokens) — this is NOT a real/contracted rate.
ADMIN_LLM_COST_PER_1K_TOKENS_USD=0

# Cloudflare R2 (S3-compatible) — per-turn user audio. Bucket is PRIVATE.
# Credentials MUST come from the environment; never commit real values.
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=<bucket_name>
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_SIGNED_URL_TTL_SECONDS=900
